{
  "name": "nest-next-app",
  "version": "1.0.0",
  "description": "NestJS + Next.js integrated application",
  "scripts": {
    "build": "nest build && next build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"lib/**/*.ts\"",
    "start": "nest start",
    "start:dev": "NODE_ENV=development NODE_NO_WARNINGS=1 nodemon",
    "start:sit": "NODE_ENV=sit NODE_NO_WARNINGS=1 nodemon",
    "start:prod": "NODE_ENV=production node dist/main",
    "build:dev": "NODE_ENV=development npm run build",
    "build:sit": "NODE_ENV=sit npm run build",
    "build:prod": "NODE_ENV=production npm run build",
    "deploy:dev": "npm run build:dev && NODE_ENV=development npm run start:prod",
    "deploy:sit": "npm run build:sit && NODE_ENV=sit npm run start:prod",
    "deploy:prod": "npm run build:prd && NODE_ENV=production npm run start:prod",
    "lint": "eslint \"{src,lib,apps}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "husky install"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/typeorm": "^11.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/passport-jwt": "^4.0.1",
    "autoprefixer": "^10.4.27",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.19.0",
    "next": "^14.1.0",
    "next-intl": "^4.8.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.2.1",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "zustand": "^5.0.11"
  }
}
